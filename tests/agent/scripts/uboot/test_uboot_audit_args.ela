# Interactive/script coverage for uboot audit
uboot audit --help
ela uboot audit --help
embedded_linux_audit uboot audit --help
uboot audit --list-rules
ela uboot audit --rule uboot_validate_crc32 --dev /dev/null --size 0x10000
embedded_linux_audit --output-format json uboot audit --rule uboot_validate_crc32 --dev /dev/null --size 0x10000